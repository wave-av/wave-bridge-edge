  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4.20250528.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.50.0"
  }
}
